# ===================================
# Kartels.io Environment Variables
# ===================================
#
# This file contains all environment variables needed to run Kartels.io.
# Copy this file to .env and fill in the values.
#
# IMPORTANT: Never commit .env to version control!
#
# For Lovable Cloud deployments, most of these are auto-configured.
# For self-hosting, you need to configure these manually.

# ===================================
# Supabase Configuration (REQUIRED)
# ===================================
# These are automatically generated by Lovable Cloud.
# For self-hosting, create a project at https://supabase.com

# Supabase Project URL
# Example: https://abcdefghijklmnop.supabase.co
VITE_SUPABASE_URL=your_supabase_url_here

# Supabase Anonymous Key (Public Key)
# This is safe to expose in client-side code
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key_here

# Supabase Project ID
# Example: abcdefghijklmnop
VITE_SUPABASE_PROJECT_ID=your_project_id_here

# ===================================
# API Configuration (OPTIONAL)
# ===================================
# Custom API base URL if using external APIs
# Default: Uses Supabase functions
# VITE_API_BASE_URL=https://api.kartels.io

# ===================================
# Feature Flags (OPTIONAL)
# ===================================
# Enable mock mode for local development without backend
# When true, uses mock data from /mocks directory
VITE_ENABLE_MOCK_MODE=false

# Enable debug mode for additional console logging
# VITE_DEBUG_MODE=false

# ===================================
# Google OAuth (SERVER-SIDE ONLY)
# ===================================
# These are managed as secrets in Lovable Cloud or Supabase
# DO NOT add these to .env - they are server-side only!
#
# Configure in Lovable Cloud → Auth Settings → Google
# Or in Supabase Dashboard → Authentication → Providers → Google
#
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# ===================================
# Google Drive Integration (SERVER-SIDE ONLY)
# ===================================
# These are managed as secrets in Lovable Cloud
# Used by the upload-to-drive edge function
#
# GOOGLE_DRIVE_FOLDER_ID=your_folder_id
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ===================================
# Supabase Service Role (SERVER-SIDE ONLY)
# ===================================
# Never expose these keys in client-side code!
# Used for server-side operations and edge functions
#
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# SUPABASE_DB_URL=postgresql://...

# ===================================
# Development Settings
# ===================================
# Port for development server (default: 8080)
# PORT=8080

# Host for development server (default: ::)
# HOST=::

# ===================================
# Production Settings
# ===================================
# Set to 'production' when deploying
# NODE_ENV=production

# ===================================
# Additional Notes
# ===================================
#
# 1. VITE_ prefix:
#    - Variables with VITE_ prefix are exposed to client-side code
#    - Do NOT use VITE_ prefix for secrets!
#
# 2. Lovable Cloud:
#    - Most variables are auto-configured
#    - Secrets managed via Cloud → Secrets interface
#    - No need to manually set SUPABASE_* variables
#
# 3. Self-Hosting:
#    - All VITE_* variables must be set
#    - Server-side secrets configured in hosting platform
#    - See README.md for deployment guides
#
# 4. Local Development:
#    - Copy this file to .env
#    - Get Supabase credentials from Lovable Cloud or supabase.com
#    - Enable VITE_ENABLE_MOCK_MODE=true to work without backend
#
# 5. Security:
#    - Never commit .env to Git
#    - .env is in .gitignore by default
#    - Rotate keys if accidentally exposed
#    - Use different keys for dev/staging/production
#
# For more information, see:
# - README.md - Environment Variables section
# - DEV_GUIDE.md - Development workflow
# - https://docs.lovable.dev/features/cloud - Lovable Cloud docs
